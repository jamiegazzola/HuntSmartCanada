

/* ══════════════════════════════════════════════════════
   CONNECT HUNTING PARTNERS  —  hunting-partners.js
   ══════════════════════════════════════════════════════ */

/* ── Dropdown item ── */
.hp-dropdown-item {
  display: flex !important;
  align-items: center !important;
  gap: 9px !important;
  width: 100% !important;
  padding: 9px 14px !important;
  background: none !important;
  border: none !important;
  border-radius: 6px !important;
  color: var(--text-dim) !important;
  font-family: 'DM Sans', sans-serif !important;
  font-size: 13px !important;
  font-weight: 500 !important;
  cursor: pointer !important;
  text-align: left !important;
  transition: background 0.13s, color 0.13s !important;
  position: relative !important;
}
.hp-dropdown-item:hover {
  background: var(--surface2) !important;
  color: var(--white) !important;
}
.hp-dropdown-item svg { opacity: 0.7; flex-shrink: 0; }
.hp-dropdown-item:hover svg { opacity: 1; }

.hp-dropdown-divider {
  height: 1px;
  background: var(--border);
  margin: 4px 0;
}

/* ── Nav badge (incoming request count on dropdown item) ── */
.hp-nav-badge {
  margin-left: auto;
  background: #e05252;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 10px;
  line-height: 1.5;
  min-width: 18px;
  text-align: center;
}

/* ── Modal overlay ── */
.hp-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 9000;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(3px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.22s ease;
}
.hp-modal-overlay.hp-modal--open {
  opacity: 1;
  pointer-events: auto;
}
.hp-modal-overlay.hp-modal--closing {
  opacity: 0;
  pointer-events: none;
}

/* ── Modal box ── */
.hp-modal {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: 16px;
  width: 100%;
  max-width: 480px;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24px 80px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.04);
  transform: translateY(8px) scale(0.98);
  transition: transform 0.22s ease, opacity 0.22s ease;
  overflow: hidden;
}
.hp-modal-overlay.hp-modal--open .hp-modal {
  transform: translateY(0) scale(1);
}

/* ── Modal header ── */
.hp-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px 0;
  flex-shrink: 0;
}
.hp-modal-title-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.hp-modal-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.2px;
}
.hp-modal-close {
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: var(--text-dim);
  cursor: pointer;
  transition: background 0.13s, color 0.13s;
  flex-shrink: 0;
}
.hp-modal-close:hover { background: var(--surface3); color: var(--white); }

/* ── Tabs ── */
.hp-tabs {
  display: flex;
  gap: 4px;
  padding: 14px 20px 0;
  flex-shrink: 0;
  border-bottom: 1px solid var(--border);
}
.hp-tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text-dim);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  padding: 0 4px 10px;
  cursor: pointer;
  transition: color 0.13s, border-color 0.13s;
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: -1px;
}
.hp-tab:hover { color: var(--text); }
.hp-tab.hp-tab--active {
  color: var(--white);
  border-bottom-color: var(--accent-bright);
}
.hp-tab-count {
  background: var(--surface3);
  color: var(--text-dim);
  font-size: 10px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 8px;
  min-width: 18px;
  text-align: center;
  line-height: 1.6;
}
.hp-tab-badge {
  background: #e05252;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 8px;
  min-width: 18px;
  text-align: center;
  line-height: 1.6;
}

/* ── Modal body (scrollable) ── */
.hp-modal-body {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
  padding: 16px 20px;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.hp-modal-body::-webkit-scrollbar { width: 4px; }
.hp-modal-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* ── Loading spinner ── */
.hp-loading {
  display: flex; align-items: center; justify-content: center;
  padding: 48px 0;
}
.hp-spinner {
  width: 24px; height: 24px;
  border: 2px solid var(--border);
  border-top-color: var(--accent-bright);
  border-radius: 50%;
  animation: hp-spin 0.7s linear infinite;
}
@keyframes hp-spin { to { transform: rotate(360deg); } }

/* ── Empty state ── */
.hp-empty {
  text-align: center;
  padding: 36px 16px;
}
.hp-empty-icon { font-size: 36px; margin-bottom: 12px; line-height: 1; }
.hp-empty-title {
  font-family: 'Playfair Display', serif;
  font-size: 17px; font-weight: 700;
  color: var(--white); margin-bottom: 8px;
}
.hp-empty-sub { font-size: 13px; color: var(--text-dim); line-height: 1.65; max-width: 300px; margin: 0 auto; }

/* ── Section labels ── */
.hp-req-section-label,
.hp-draw-section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}

/* ── Partner row ── */
.hp-partners-list { display: flex; flex-direction: column; gap: 2px; }
.hp-partner-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  border-radius: 10px;
  background: var(--surface2);
  border: 1px solid var(--border);
  transition: border-color 0.13s;
}
.hp-partner-row:hover { border-color: var(--border-light); }

.hp-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: 13px; font-weight: 700; color: var(--white);
  background-size: cover;
  background-position: center;
  overflow: hidden;
}

.hp-partner-info { flex: 1; min-width: 0; }
.hp-partner-name {
  font-size: 13px; font-weight: 600; color: var(--white);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.hp-partner-email,
.hp-partner-status {
  font-size: 11px; color: var(--text-muted);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  margin-top: 2px;
}

.hp-partner-actions {
  display: flex; gap: 6px; align-items: center; flex-shrink: 0;
}

/* ── Action buttons ── */
.hp-btn-ghost {
  display: flex; align-items: center; gap: 5px;
  padding: 5px 11px;
  background: transparent;
  border: 1px solid var(--border-light);
  border-radius: 6px;
  color: var(--text-dim);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px; font-weight: 600;
  cursor: pointer;
  transition: all 0.13s;
  white-space: nowrap;
}
.hp-btn-ghost:hover { border-color: var(--accent2); color: var(--accent-bright); background: var(--accent-dim); }

.hp-btn-accept {
  padding: 5px 12px;
  background: var(--accent);
  border: none;
  border-radius: 6px;
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px; font-weight: 700;
  cursor: pointer;
  transition: background 0.13s;
  white-space: nowrap;
}
.hp-btn-accept:hover { background: var(--accent2); }

.hp-btn-remove {
  padding: 5px 11px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px; font-weight: 600;
  cursor: pointer;
  transition: all 0.13s;
  white-space: nowrap;
}
.hp-btn-remove:hover { border-color: #b03a2a; color: #e05252; background: rgba(176,58,42,0.08); }

.hp-pending-pill {
  font-size: 10px; font-weight: 700;
  padding: 3px 9px;
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* ── Modal footer (add partner) ── */
.hp-modal-footer {
  padding: 14px 20px 18px;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
  background: var(--surface);
}
.hp-add-row {
  display: flex;
  gap: 8px;
}
.hp-add-field-wrap {
  position: relative;
  flex: 1;
}
.hp-email-input {
  width: 100%;
  padding: 9px 12px 9px 34px;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 8px;
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  outline: none;
  transition: border-color 0.15s;
}
.hp-email-input::placeholder { color: var(--text-muted); }
.hp-email-input:focus { border-color: var(--accent2); }

.hp-send-btn {
  display: flex; align-items: center; gap: 7px;
  padding: 9px 16px;
  background: var(--accent);
  border: none;
  border-radius: 8px;
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 700;
  cursor: pointer;
  transition: background 0.13s;
  white-space: nowrap;
  flex-shrink: 0;
}
.hp-send-btn:hover { background: var(--accent2); }
.hp-send-btn:disabled { opacity: 0.5; cursor: default; }

.hp-add-msg {
  margin-top: 8px;
  font-size: 12px;
  padding: 7px 10px;
  border-radius: 6px;
}
.hp-add-msg--success {
  background: rgba(58,173,82,0.1);
  border: 1px solid rgba(58,173,82,0.25);
  color: var(--green);
}
.hp-add-msg--error {
  background: rgba(176,58,42,0.1);
  border: 1px solid rgba(176,58,42,0.25);
  color: #e05252;
}

/* ── Partner's saved draws view ── */
.hp-back-btn {
  background: none;
  border: none;
  color: var(--text-dim);
  font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 600;
  cursor: pointer;
  padding: 4px 0;
  transition: color 0.13s;
  display: flex; align-items: center; gap: 4px;
}
.hp-back-btn:hover { color: var(--accent-bright); }

.hp-partner-draws-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
}
.hp-partner-draws-title {
  font-size: 14px; font-weight: 700; color: var(--white);
}
.hp-partner-draws-count {
  font-size: 11px; color: var(--text-muted);
  background: var(--surface3);
  padding: 2px 8px; border-radius: 8px;
}
.hp-draws-list { display: flex; flex-direction: column; gap: 2px; }
.hp-draw-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 9px 12px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  gap: 12px;
  transition: border-color 0.13s;
}
.hp-draw-row:hover { border-color: var(--border-light); }
.hp-draw-info { flex: 1; min-width: 0; }
.hp-draw-code {
  font-size: 13px; font-weight: 600; color: var(--white);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.hp-draw-meta {
  font-size: 11px; color: var(--text-muted); margin-top: 2px;
}
.hp-draw-prov {
  color: var(--accent-bright); font-weight: 600;
}
.hp-draw-odds {
  font-family: 'Playfair Display', serif;
  font-size: 15px; font-weight: 700;
  color: var(--text-dim);
  flex-shrink: 0;
}

/* ── Toast ── */
.hp-toast {
  position: fixed;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%) translateY(12px);
  background: var(--surface3);
  border: 1px solid var(--border-light);
  border-radius: 10px;
  padding: 10px 20px;
  font-size: 13px; font-weight: 600;
  color: var(--white);
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  z-index: 99999;
  opacity: 0;
  transition: opacity 0.2s, transform 0.2s;
  pointer-events: none;
  white-space: nowrap;
}
.hp-toast.hp-toast--show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ── Mobile ── */
@media (max-width: 600px) {
  .hp-modal { max-height: 90vh; border-radius: 16px 16px 0 0; align-self: flex-end; }
  .hp-modal-overlay { align-items: flex-end; padding: 0; }
  .hp-modal-overlay.hp-modal--open .hp-modal { transform: translateY(0) scale(1); }
  .hp-modal .hp-modal { transform: translateY(20px) scale(1); }
  .hp-partner-row { flex-wrap: wrap; }
  .hp-partner-actions { width: 100%; justify-content: flex-end; }
  .hp-add-row { flex-direction: column; }
  .hp-send-btn { justify-content: center; }
}

/* ── Auth menu item (matches auth dropdown base style) ── */
.auth-menu-item {
  display: flex;
  align-items: center;
  gap: 9px;
  width: 100%;
  padding: 8px 12px;
  background: none;
  border: none;
  border-radius: 7px;
  color: var(--text-secondary, var(--text-dim));
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  text-align: left;
  transition: background 0.13s, color 0.13s;
}
.auth-menu-item:hover {
  background: var(--surface2);
  color: var(--white);
}
.auth-menu-item svg { opacity: 0.7; flex-shrink: 0; }
.auth-menu-item:hover svg { opacity: 1; }
